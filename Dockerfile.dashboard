FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Streamlit precisa disso no Render
ENV PORT=8501

CMD ["sh", "-c", "streamlit run src/infrastructure/dashboard/streamlit_app.py --server.port $PORT --server.address 0.0.0.0"]