FROM python:3.12-slim

WORKDIR /app

COPY . .

RUN pip install --no-cache-dir -r requirements.txt

# 🔥 ESSENCIAL
ENV PYTHONPATH=/app

# 🔥 ESSENCIAL PARA RENDER
ENV PORT=10000

EXPOSE 10000

CMD ["sh", "-c", "streamlit run src/infrastructure/dashboard/streamlit_dashboard.py --server.port=$PORT --server.address=0.0.0.0"]